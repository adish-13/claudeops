# Root binary only — anchored so `cmd/claudeops/` (the package directory)
# is NOT ignored. Without the leading slash this pattern was silently
# excluding cmd/claudeops/ from the repo entirely.
/claudeops
*.db
*.db-wal
*.db-shm

# Built frontend assets — produced by `make web`, embedded by Go at build time.
internal/server/dist/

# Node toolchain — installed via `npm install` in web/.
web/node_modules/
